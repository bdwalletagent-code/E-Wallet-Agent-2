rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "bdwalletagent@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/agents/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/agents/$(request.auth.uid)).data.role == "admin")
      );
    }

    // Rule for user/agent profiles
    match /agents/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Rule for Transactions
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        (resource == null && request.resource.data.agentId == request.auth.uid) ||
        (resource != null && resource.data.agentId == request.auth.uid)
      );
    }

    // Rule for Agent Cash Requests (Deposits into their own Agent account)
    match /agentCashRequests/{requestId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        (resource == null && request.resource.data.agentId == request.auth.uid) ||
        (resource != null && resource.data.agentId == request.auth.uid)
      );
    }

    // Rule for Agent Withdraw Requests (Withdrawing their earned commission)
    match /agentWithdrawRequests/{requestId} {
      allow read, write: if isSignedIn() && (
        isAdmin() ||
        (resource == null && request.resource.data.agentId == request.auth.uid) ||
        (resource != null && resource.data.agentId == request.auth.uid)
      );
    }

    // Admin profiles lookup
    match /admins/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
  }
}
